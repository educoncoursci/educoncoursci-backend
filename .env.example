# ============================================================
#  EduConcoursCI — Variables d'environnement
#  Copie ce fichier en .env et remplis tes vraies valeurs.
#  Ne jamais envoyer .env sur GitHub (il est dans .gitignore).
# ============================================================

# ── Serveur ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5500

# ── Base de données PostgreSQL ───────────────────────────────
# En local : postgresql://postgres:motdepasse@localhost:5432/educoncoursci
# Sur Railway : copie l'URL fournie par Railway
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ── JWT (authentification) ───────────────────────────────────
# Génère une clé aléatoire longue : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_moi_par_une_longue_chaine_aleatoire
JWT_EXPIRES_IN=7d

# ── Paiement Wave & Orange Money ─────────────────────────────
WAVE_NUMERO=07XXXXXXXX
OM_NUMERO=05XXXXXXXX

# ── IA Claude (génération CV/LM) ─────────────────────────────
# Récupère ta clé sur https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── E-mails (Nodemailer via Gmail) ───────────────────────────
# Active "Mots de passe des applications" dans ton compte Google
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=ton.email@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx
EMAIL_FROM=EduConcoursCI <noreply@educoncoursci.ci>

# ── Admin par défaut ─────────────────────────────────────────
# Créé automatiquement au premier démarrage si la table est vide
ADMIN_EMAIL=admin@educoncoursci.ci
ADMIN_PASSWORD=change_moi_au_premier_lancement

# ── Upload fichiers ──────────────────────────────────────────
MAX_FILE_SIZE_MB=20
UPLOAD_PATH=./uploads/pdf
